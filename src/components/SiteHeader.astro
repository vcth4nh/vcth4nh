---
import { profile } from "../data/profile";
import PresentationSwitch from "./PresentationSwitch.astro";
import ProtectedEmail from "./ProtectedEmail.astro";

const pathname = Astro.url.pathname;
const links = [
  { label: "Research", href: "/research/" },
  { label: "Projects", href: "/projects/" },
  { label: "Résumé", href: "/resume/" },
];

const isActive = (href: string) =>
  href === "/" ? pathname === href : pathname.startsWith(href);
---

<header class="site-header" data-site-header>
  <div class="shell header-inner">
    <a class="wordmark header-wordmark" href="/" aria-label={`/${profile.handle} — ${profile.name}, home`}>
      <span class="wordmark-prompt" aria-hidden="true">/</span>{profile.handle}
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {links.map((link, index) => (
        <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
          <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
          <span>{link.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-tools">
      <PresentationSwitch current="classic" class="classic-presentation-switch" />
      <ProtectedEmail label="Start a conversation" class="header-contact" />
    </div>

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobile navigation">
        {links.map((link) => (
          <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
            {link.label}
          </a>
        ))}
        <PresentationSwitch current="classic" class="mobile-presentation-switch" />
        <ProtectedEmail label="Start a conversation" />
      </nav>
    </details>
  </div>
</header>
