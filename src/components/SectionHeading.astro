---
interface Props {
  index: string;
  title: string;
  intro?: string;
  link?: { label: string; href: string };
}

const { index, title, intro, link } = Astro.props;
---

<header class="section-heading">
  <div class="section-kicker"><span>{index}</span><span aria-hidden="true">↘</span></div>
  <div>
    <h2>{title}</h2>
    {intro && <p>{intro}</p>}
  </div>
  {link && <a class="text-link" href={link.href}>{link.label}<span aria-hidden="true">→</span></a>}
</header>
