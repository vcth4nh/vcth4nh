---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { profile } from "../data/profile";
import "../styles/global.css";
import "../styles/retro.css";

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  noindex?: boolean;
  unwrapped?: boolean;
}

const {
  title,
  description = profile.summary,
  pageClass = "",
  noindex = false,
  unwrapped = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${profile.name}` : `${profile.name} / ${profile.handle}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL("/og.png", Astro.site);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  alternateName: profile.handle,
  url: profile.siteUrl,
  jobTitle: profile.title,
  description: profile.positioning,
  sameAs: profile.socials.map((social) => social.href),
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "Hanoi University of Science and Technology" },
  ],
  knowsAbout: [
    "Vulnerability research",
    "Exploit development",
    "Application security",
    "AI-assisted security tooling",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b0c0b" />
    <script is:inline>
      (() => {
        let presentation = "field-notes";

        try {
          const requestedPresentation = new URLSearchParams(window.location.search).get("presentation");
          const savedPresentation = window.localStorage.getItem("profile-presentation");

          if (requestedPresentation === "classic" || requestedPresentation === "field-notes") {
            presentation = requestedPresentation;
            window.localStorage.setItem("profile-presentation", presentation);
          } else if (savedPresentation === "classic" || savedPresentation === "field-notes") {
            presentation = savedPresentation;
          }
        } catch {
          // Field Notes remains the default when storage is unavailable.
        }

        document.documentElement.dataset.presentation = presentation;
      })();
    </script>
    <script is:inline>
      (() => {
        const allowedThemes = new Set(["phosphor", "sage", "harbor", "grove", "signal"]);
        const requestedTheme = new URLSearchParams(window.location.search).get("theme");
        let theme = requestedTheme;

        if (theme && allowedThemes.has(theme)) {
          window.sessionStorage.setItem("preview-theme", theme);
        } else {
          theme = window.sessionStorage.getItem("preview-theme") || "phosphor";
        }

        if (!allowedThemes.has(theme)) theme = "phosphor";
        document.documentElement.dataset.theme = theme;

        const browserColors = {
          phosphor: "#0b0c0b",
          sage: "#40513b",
          harbor: "#124076",
          grove: "#0d530e",
          signal: "#0c2c4a",
        };
        const activeBrowserColor = document.documentElement.dataset.presentation === "field-notes"
          ? "#0a746a"
          : browserColors[theme];
        document.querySelector('meta[name="theme-color"]')?.setAttribute("content", activeBrowserColor);
      })();
    </script>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{pageTitle}</title>
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader />
    {unwrapped ? <slot /> : <main id="main"><slot /></main>}
    <SiteFooter />
  </body>
</html>
